# Base URL of the gargantua backend.
#
# Dev (UI on :3000, backend on :7777):
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:7777
#
# Prod (UI served by FastAPI from the same origin under /):
#   NEXT_PUBLIC_API_BASE_URL=
#
# Notes:
#  * Anything prefixed with ``NEXT_PUBLIC_`` is inlined into the built
#    JS bundle at compile time, so changing it requires a rebuild.
#  * Empty string is meaningful — it means "use a relative URL", which
#    is exactly what we want when FastAPI serves the UI itself.
NEXT_PUBLIC_API_BASE_URL=http://localhost:7777
