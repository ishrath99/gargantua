# ---------------------------------------------------------------------------
# Gargantua — environment configuration
# Copy to .env and fill in the values.
# ---------------------------------------------------------------------------

# Runtime ----------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=7777
APP_LOG_LEVEL=info
# 'dev' skips JWT enforcement so you can iterate; 'prd' enforces it.
RUNTIME_ENV=dev

# Database --------------------------------------------------------------------
# Sync URL  (Alembic, Agno's PostgresDb) — psycopg-3 sync engine.
DATABASE_URL=postgresql+psycopg://gargantua:gargantua@localhost:5432/gargantua
# Async URL (FastAPI request handlers) — same psycopg-3 dialect; SQLAlchemy
# picks sync vs async based on create_engine() vs create_async_engine().
DATABASE_URL_ASYNC=postgresql+psycopg://gargantua:gargantua@localhost:5432/gargantua

# Compose-internal Postgres password.  Only honoured by docker-compose.yml,
# which interpolates it into both POSTGRES_PASSWORD and the two DATABASE_URL*
# variables above when the app talks to the ``postgres`` service.  Override
# this for any deployment you would not throw away.
# POSTGRES_PASSWORD=gargantua

# LLM provider keys -----------------------------------------------------------
# The model used for each agent is configured per-row on `agents.model`
# (free-form string like "openrouter:anthropic/claude-3.5-sonnet" or
# "openai:gpt-4o-mini").  Agno reads the corresponding API key from one of
# the provider-specific env vars below — set whichever ones match the
# models your agents use.
#
# OpenRouter is the easiest path: one key fronts every major model.
# Browse the catalog at https://openrouter.ai/models and reference models
# as "openrouter:<vendor>/<model>" in the agent's `model` column.
OPENROUTER_API_KEY=

# Native provider keys (only needed if you reference these providers
# directly, e.g. "openai:gpt-4o", "anthropic:claude-sonnet-4-20250514").
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# Secrets at rest (KEK) -------------------------------------------------------
# 32 random bytes, base64-encoded. Generate once:
#     gargantua-admin generate-master-key
# Used to AES-256-GCM-encrypt MCP server credentials (env_vars) and child
# resource headers before they hit Postgres. The kek_id column stores a
# short fingerprint so a row knows which KEK can decrypt it.
#
# Rotation: when this needs to change, generate a new key and run
#     gargantua-admin rotate-kek --from-key <old-b64> --to-key <new-b64>
# while no writers are touching the secrets tables. Then update MASTER_KEY
# and restart the app.
#
# WARNING: losing this key means every MCP server's secret values must be
# re-entered. Back it up in a separate secret store from the database.
MASTER_KEY=

# JWT (RS256) -----------------------------------------------------------------
# Generate the keypair with:
#     gargantua-admin generate-jwt-keys --out-dir ./secrets
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ISSUER=gargantua
JWT_AUDIENCE=gargantua
JWT_ACCESS_TTL_SECONDS=43200
JWT_REFRESH_TTL_SECONDS=2592000

# Bootstrap admin -------------------------------------------------------------
# If the users table is empty on startup AND both of these are set, the first
# admin account is created. Leave blank on subsequent boots.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# MCP cache -------------------------------------------------------------------
# How long a warm MCP server subprocess stays cached after its last use.
MCP_CACHE_IDLE_TTL_SECONDS=300
MCP_CACHE_REAPER_INTERVAL_SECONDS=30

# CORS ------------------------------------------------------------------------
# Comma-separated list. The bundled UI is served from the same origin in prod,
# so this matters mainly for `pnpm dev` against the FastAPI backend.
CORS_ORIGINS=http://localhost:3000

# UI mount --------------------------------------------------------------------
# Where the FastAPI app looks for the Next.js static export. When the
# directory exists the UI is mounted at `/`. Inside the Docker image this is
# pre-set to `/app/ui/out`; for venv-on-host runs the default `./ui/out`
# matches what `pnpm --dir ui build` produces.
# UI_STATIC_ROOT=./ui/out

# Agno debug ------------------------------------------------------------------
# When true, every transient Agent / Team is built with `debug_mode=True`.
# Agno then bumps its own loggers (`agno`, `agno-team`) to DEBUG and prints
# the full run trace — model prompts, tool calls + args + results,
# intermediate reasoning — to the uvicorn console.  Invaluable for
# diagnosing opaque MCP tool errors ("fetch failed", auth failures, ...).
# Leave OFF in production: prompts and tool args often contain sensitive
# data and the traces are noisy at scale.
# AGNO_DEBUG=false
